rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.admin == 'true'
      );
    }
    function isClerk() {
      return isSignedIn() && request.auth.token.role == 'clerk';
    }
    function isStaff() {
      return isAdmin() || isClerk();
    }
    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }
    // JS and rules both use floats; strict == on money often fails (e.g. 0.1 * 3).
    function approxMoneyEq(a, b) {
      return a is number && b is number && a >= b - 0.05 && a <= b + 0.05;
    }
    // Invoice header totals can be large; float error can exceed cents.
    function approxHeaderMoneyEq(a, b) {
      return a is number && b is number && a >= b - 100.0 && a <= b + 100.0;
    }
    // Missing field vs null breaks plain == between resource and request on update.
    function voidedAtUnchanged(res, req) {
      return (!('voided_at' in res) && !('voided_at' in req)) || req.voided_at == res.voided_at;
    }
    function postedAtUnchanged(res, req) {
      return (!('posted_at' in res) && !('posted_at' in req)) || req.posted_at == res.posted_at;
    }
    function validCustomerBase(data) {
      return hasOnlyKeys(
        data,
        ['name', 'phone', 'email', 'address', 'is_active', 'created_at', 'updated_at', 'archived_at']
      )
      && data.name is string
      && data.name.size() >= 2
      && data.name.size() <= 120
      && (!('phone' in data) || (data.phone is string && data.phone.size() <= 25))
      && (!('email' in data) || (data.email is string && data.email.size() <= 120))
      && (!('address' in data) || (data.address is string && data.address.size() <= 300))
      && data.is_active is bool
      && data.created_at is timestamp
      && data.updated_at is timestamp
      && (!('archived_at' in data) || data.archived_at is timestamp);
    }
    // No hasOnlyKeys: extra fields from legacy/console data must not block updates.
    function validInvoiceBase(data) {
      return data.customer_id is string
      && data.customer_id.size() > 0
      && data.order_id is string
      && data.order_id.size() >= 6
      && data.order_id.size() <= 40
      && data.status in ['draft', 'posted', 'void']
      && data.payment_status in ['unpaid', 'partial', 'paid']
      && data.paid_amount is number
      && data.paid_amount >= 0
      && data.stock_reversal_applied is bool
      && data.item_ids is list
      && data.item_ids.size() > 0
      && data.subtotal_amount is number
      && data.discount_amount is number
      && data.delivery_charge is number
      && data.total_amount is number
      && data.subtotal_amount >= 0
      && data.discount_amount >= 0
      && data.delivery_charge >= 0
      && data.total_amount >= 0
      && data.paid_amount <= data.total_amount
      && approxHeaderMoneyEq(
        data.total_amount,
        data.subtotal_amount - data.discount_amount + data.delivery_charge
      )
      && (!('posted_subtotal_amount' in data) || (data.posted_subtotal_amount is number && data.posted_subtotal_amount >= 0))
      && (!('posted_discount_amount' in data) || (data.posted_discount_amount is number && data.posted_discount_amount >= 0))
      && (!('posted_delivery_charge' in data) || (data.posted_delivery_charge is number && data.posted_delivery_charge >= 0))
      && (!('posted_total_amount' in data) || (data.posted_total_amount is number && data.posted_total_amount >= 0))
      && (!('posted_cogs_amount' in data) || (data.posted_cogs_amount is number && data.posted_cogs_amount >= 0))
      && (!('notes' in data) || (data.notes is string && data.notes.size() <= 500))
      && (!('posted_at' in data) || data.posted_at == null || data.posted_at is timestamp)
      && (!('voided_at' in data) || data.voided_at == null || data.voided_at is timestamp)
      && data.created_at is timestamp
      && data.updated_at is timestamp;
    }
    function validInvoiceItemBase(data) {
      return hasOnlyKeys(
        data,
        ['invoice_id', 'order_id', 'customer_id', 'product_id', 'quantity', 'unit_price', 'line_discount', 'line_delivery_charge', 'line_total', 'created_at', 'updated_at']
      )
      && data.invoice_id is string
      && data.invoice_id.size() > 0
      && data.order_id is string
      && data.order_id.size() >= 6
      && data.order_id.size() <= 40
      && data.customer_id is string
      && data.customer_id.size() > 0
      && data.product_id is string
      && data.product_id.size() > 0
      && data.quantity is int
      && data.quantity > 0
      && data.unit_price is number
      && data.unit_price >= 0
      && data.line_discount is number
      && data.line_discount >= 0
      && data.line_delivery_charge is number
      && data.line_delivery_charge >= 0
      && data.line_total is number
      && data.line_total >= 0
      && approxMoneyEq(
        data.line_total,
        (data.quantity * data.unit_price) - data.line_discount + data.line_delivery_charge
      )
      && data.created_at is timestamp
      && data.updated_at is timestamp;
    }
    // No hasOnlyKeys: legacy or imported lots may include extra fields; strict keys blocked postInvoice tx.update.
    function validStockLotBase(data) {
      return data.product_id is string
      && data.product_id.size() > 0
      && data.unit_cost is number
      && data.unit_cost >= 0
      && data.qty_in is int
      && data.qty_in > 0
      && data.qty_remaining is int
      && data.qty_remaining >= 0
      && data.qty_remaining <= data.qty_in
      && data.source in ['stock_in', 'opening_balance', 'adjustment']
      && (!('reference_id' in data) || (data.reference_id is string && data.reference_id.size() > 0))
      && data.received_at is timestamp
      && data.created_at is timestamp
      && data.updated_at is timestamp;
    }
    function stockLotSourceTransitionAllowed(res, req) {
      return req.source == res.source
        || (res.source == 'opening_balance' && req.source == 'stock_in');
    }
    // No hasOnlyKeys: avoid false denials on shapes that match validators but add optional fields.
    function validLotConsumptionBase(data) {
      return data.invoice_id is string
      && data.invoice_id.size() > 0
      && data.order_id is string
      && data.order_id.size() >= 6
      && data.order_id.size() <= 40
      && data.invoice_item_id is string
      && data.invoice_item_id.size() > 0
      && data.product_id is string
      && data.product_id.size() > 0
      && data.lot_id is string
      && data.lot_id.size() > 0
      && data.quantity is int
      && data.quantity > 0
      && data.unit_cost is number
      && data.unit_cost >= 0
      && data.cogs_amount is number
      && data.cogs_amount >= 0
      && (
        approxMoneyEq(data.cogs_amount, data.quantity * data.unit_cost)
        || approxMoneyEq(data.unit_cost, data.cogs_amount / data.quantity)
      )
      && data.created_at is timestamp
      && (!('reversed_at' in data) || data.reversed_at is timestamp);
    }
    function validInvoiceItemCogsBase(data) {
      return data.invoice_id is string
      && data.invoice_id.size() > 0
      && data.order_id is string
      && data.order_id.size() >= 6
      && data.order_id.size() <= 40
      && data.customer_id is string
      && data.customer_id.size() > 0
      && data.invoice_item_id is string
      && data.invoice_item_id.size() > 0
      && data.product_id is string
      && data.product_id.size() > 0
      && data.quantity is int
      && data.quantity > 0
      && data.unit_sale_price is number
      && data.unit_sale_price >= 0
      && data.unit_cost_snapshot is number
      && data.unit_cost_snapshot >= 0
      && data.line_subtotal is number
      && data.line_subtotal >= 0
      && data.line_discount is number
      && data.line_discount >= 0
      && data.line_delivery_charge is number
      && data.line_delivery_charge >= 0
      && data.cogs_amount is number
      && data.cogs_amount >= 0
      && data.line_total is number
      && data.line_total >= 0
      && approxMoneyEq(data.line_subtotal, (data.quantity * data.unit_sale_price) - data.line_discount)
      && approxMoneyEq(data.line_total, data.line_subtotal + data.line_delivery_charge)
      // COGS identity: product can drift in float; allow either form (see lib/firestore/invoices postInvoice).
      && (
        approxMoneyEq(data.cogs_amount, data.quantity * data.unit_cost_snapshot)
        || approxMoneyEq(data.unit_cost_snapshot, data.cogs_amount / data.quantity)
      )
      && data.created_at is timestamp;
    }
    function validCashSettings(data) {
      return hasOnlyKeys(data, ['opening_balance', 'actual_cash_balance', 'actual_cash_updated_at', 'updated_at'])
      && data.opening_balance is number
      && (!('actual_cash_balance' in data) || data.actual_cash_balance is number)
      && (!('actual_cash_updated_at' in data) || data.actual_cash_updated_at is timestamp)
      && data.updated_at is timestamp;
    }
    function validCashEntryBase(data) {
      return hasOnlyKeys(data, ['entry_type', 'amount', 'date', 'note', 'created_at'])
      && data.entry_type in ['add', 'remove']
      && data.amount is number
      && data.amount > 0
      && data.date is timestamp
      && (!('note' in data) || (data.note is string && data.note.size() <= 500))
      && data.created_at is timestamp;
    }
    // Clerk may only edit invoices while they stay draft (no post / void / payment paths).
    function invoiceDraftToDraftOnly(res, req) {
      return res.status == 'draft'
        && req.status == 'draft'
        && postedAtUnchanged(res, req)
        && voidedAtUnchanged(res, req)
        && req.stock_reversal_applied == false;
    }
    function invoicePostedPaymentUpdateOnly(res, req) {
      return res.status == 'posted'
        && req.status == 'posted'
        && req.stock_reversal_applied == false
        && postedAtUnchanged(res, req)
        && voidedAtUnchanged(res, req)
        && req.posted_subtotal_amount == res.posted_subtotal_amount
        && req.posted_discount_amount == res.posted_discount_amount
        && req.posted_delivery_charge == res.posted_delivery_charge
        && req.posted_total_amount == res.posted_total_amount
        && req.posted_cogs_amount == res.posted_cogs_amount
        && req.customer_id == res.customer_id
        && req.order_id == res.order_id
        && req.item_ids == res.item_ids
        && req.subtotal_amount == res.subtotal_amount
        && req.discount_amount == res.discount_amount
        && req.delivery_charge == res.delivery_charge
        && req.total_amount == res.total_amount
        && req.payment_status in ['unpaid', 'partial', 'paid']
        && req.paid_amount >= res.paid_amount
        && req.paid_amount <= req.total_amount;
    }

    // Phase 1 smoke test (optional)
    match /phase1_smoke/{docId} {
      allow read, write: if isAdmin();
    }
    // MVP collections — clerks: read products for invoice lines; writes admin-only.
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /sales/{docId} {
      allow read, write: if isAdmin();
    }
    match /expenses/{docId} {
      allow read, write: if isStaff();
    }
    match /cash_entries/{docId} {
      allow read, delete: if isAdmin();
      allow create, update: if isAdmin() && validCashEntryBase(request.resource.data);
    }
    match /settings/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && docId == 'cash' && validCashSettings(request.resource.data);
      allow delete: if false;
    }
    match /customers/{docId} {
      allow read: if isStaff();
      allow create: if isStaff() && validCustomerBase(request.resource.data) && request.resource.data.is_active == true;
      allow update: if isStaff() && validCustomerBase(request.resource.data)
        && request.resource.data.created_at == resource.data.created_at;
      allow delete: if false;
    }
    match /invoices/{docId} {
      allow read: if isStaff();
      allow create: if isStaff() && validInvoiceBase(request.resource.data)
        && request.resource.data.order_id == docId
        && request.resource.data.status == 'draft'
        && request.resource.data.payment_status == 'unpaid'
        && request.resource.data.paid_amount == 0
        && request.resource.data.stock_reversal_applied == false
        && exists(/databases/$(database)/documents/customers/$(request.resource.data.customer_id));
      allow update: if validInvoiceBase(request.resource.data)
        && request.resource.data.order_id == resource.data.order_id
        && request.resource.data.created_at == resource.data.created_at
        && (
          request.resource.data.item_ids == resource.data.item_ids
          || (resource.data.status == 'draft' && request.resource.data.status == 'draft')
        )
        && (
          (isClerk() && invoiceDraftToDraftOnly(resource.data, request.resource.data))
          || (isAdmin() && (
            (
              resource.data.status == 'draft'
              && request.resource.data.status == 'draft'
              && postedAtUnchanged(resource.data, request.resource.data)
              && voidedAtUnchanged(resource.data, request.resource.data)
              && request.resource.data.stock_reversal_applied == false
            )
            || (
              resource.data.status == 'draft'
              && request.resource.data.status == 'posted'
              && request.resource.data.posted_at is timestamp
              && voidedAtUnchanged(resource.data, request.resource.data)
              && approxHeaderMoneyEq(
                request.resource.data.posted_subtotal_amount,
                resource.data.subtotal_amount
              )
              && approxHeaderMoneyEq(
                request.resource.data.posted_discount_amount,
                resource.data.discount_amount
              )
              && approxHeaderMoneyEq(
                request.resource.data.posted_delivery_charge,
                resource.data.delivery_charge
              )
              && approxHeaderMoneyEq(
                request.resource.data.posted_total_amount,
                resource.data.total_amount
              )
              && request.resource.data.posted_cogs_amount is number
              && request.resource.data.posted_cogs_amount >= 0
              && request.resource.data.stock_reversal_applied == false
            )
            || (
              resource.data.status == 'draft'
              && request.resource.data.status == 'void'
              && request.resource.data.stock_reversal_applied == false
              && request.resource.data.voided_at is timestamp
              && postedAtUnchanged(resource.data, request.resource.data)
              && request.resource.data.posted_subtotal_amount == resource.data.posted_subtotal_amount
              && request.resource.data.posted_discount_amount == resource.data.posted_discount_amount
              && request.resource.data.posted_delivery_charge == resource.data.posted_delivery_charge
              && request.resource.data.posted_total_amount == resource.data.posted_total_amount
              && request.resource.data.posted_cogs_amount == resource.data.posted_cogs_amount
            )
            || (
              invoicePostedPaymentUpdateOnly(resource.data, request.resource.data)
            )
            || (
              resource.data.status == 'posted'
              && request.resource.data.status == 'void'
              && request.resource.data.stock_reversal_applied == true
              && request.resource.data.voided_at is timestamp
              && postedAtUnchanged(resource.data, request.resource.data)
              && request.resource.data.posted_subtotal_amount == resource.data.posted_subtotal_amount
              && request.resource.data.posted_discount_amount == resource.data.posted_discount_amount
              && request.resource.data.posted_delivery_charge == resource.data.posted_delivery_charge
              && request.resource.data.posted_total_amount == resource.data.posted_total_amount
              && request.resource.data.posted_cogs_amount == resource.data.posted_cogs_amount
            )
          ))
        );
      allow delete: if isStaff() && resource.data.status == 'draft' && resource.data.stock_reversal_applied == false;
    }
    // Note: draft invoice + line items are created in one transaction. Rules cannot see
    // uncommitted writes, so exists(get) on the parent invoice would always fail.
    // Keep create validation shape-only to avoid exceeding the 20 access-call limit
    // when creating larger invoices (product existence is preflight-validated in app code).
    match /invoice_items/{docId} {
      allow read: if isStaff();
      allow create: if isStaff() && validInvoiceItemBase(request.resource.data);
      allow update: if false;
      allow delete: if isStaff() && resource.data.invoice_id is string
        && resource.data.invoice_id.size() > 0
        && exists(/databases/$(database)/documents/invoices/$(resource.data.invoice_id))
        && get(/databases/$(database)/documents/invoices/$(resource.data.invoice_id)).data.status == 'draft';
    }
    match /stock_lots/{docId} {
      allow read: if isAdmin();
      // Omit exists(product): admin-only create; avoids one exists() per opening_balance lot during invoice post
      // (transactions are limited to 20 cross-document rule reads total).
      allow create: if isAdmin() && validStockLotBase(request.resource.data);
      allow update: if isAdmin() && validStockLotBase(request.resource.data)
        && request.resource.data.product_id == resource.data.product_id
        && request.resource.data.qty_in == resource.data.qty_in
        && stockLotSourceTransitionAllowed(resource.data, request.resource.data)
        && request.resource.data.received_at == resource.data.received_at
        && request.resource.data.created_at == resource.data.created_at;
      // Temporary: allow admin to remove mistaken lots; prefer editing qty/cost when possible.
      allow delete: if isAdmin();
    }
    // Posting can create an opening_balance lot and consumptions in the same transaction; exists(lot) would fail.
    // Use one get(invoice) + item_ids membership instead of two exists() — transactions share a 20 get/exists budget.
    match /lot_consumptions/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && validLotConsumptionBase(request.resource.data)
        && request.resource.data.invoice_item_id in get(/databases/$(database)/documents/invoices/$(request.resource.data.invoice_id)).data.item_ids
        && !('reversed_at' in request.resource.data);
      allow update: if isAdmin() && validLotConsumptionBase(request.resource.data)
        && request.resource.data.invoice_id == resource.data.invoice_id
        && request.resource.data.order_id == resource.data.order_id
        && request.resource.data.invoice_item_id == resource.data.invoice_item_id
        && request.resource.data.product_id == resource.data.product_id
        && request.resource.data.lot_id == resource.data.lot_id
        && request.resource.data.quantity == resource.data.quantity
        && request.resource.data.unit_cost == resource.data.unit_cost
        && request.resource.data.cogs_amount == resource.data.cogs_amount
        && request.resource.data.created_at == resource.data.created_at
        && !('reversed_at' in resource.data)
        && request.resource.data.reversed_at is timestamp;
      allow delete: if false;
    }
    // One logical read of invoices/{id} (cached across duplicate get paths) + item_ids check — saves exists() budget.
    match /invoice_item_cogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && validInvoiceItemCogsBase(request.resource.data)
        && request.resource.data.invoice_item_id == docId
        && request.resource.data.invoice_item_id in get(/databases/$(database)/documents/invoices/$(request.resource.data.invoice_id)).data.item_ids
        && request.resource.data.order_id
          == get(/databases/$(database)/documents/invoices/$(request.resource.data.invoice_id)).data.order_id
        && request.resource.data.customer_id
          == get(/databases/$(database)/documents/invoices/$(request.resource.data.invoice_id)).data.customer_id;
      allow update, delete: if false;
    }
    function validWalkInSessionCreate(data) {
      return data.status == 'pending'
        && data.sale_date is timestamp
        && data.line_count is int
        && data.line_count > 0
        && data.created_at is timestamp
        && data.updated_at is timestamp
        && (!('created_by_uid' in data) || (data.created_by_uid is string && data.created_by_uid.size() > 0));
    }
    function validWalkInLine(data) {
      return data.product_id is string
        && data.product_id.size() > 0
        && data.quantity is int
        && data.quantity > 0
        && data.unit_sale_price is number
        && data.unit_sale_price >= 0
        && data.created_at is timestamp;
    }
    function walkInStaffEditPending(res, req) {
      return res.status == 'pending'
        && req.status == 'pending'
        && req.created_at == res.created_at
        && req.sale_date is timestamp
        && req.line_count is int
        && req.line_count > 0
        && req.updated_at is timestamp
        && (!('created_by_uid' in res) || req.created_by_uid == res.created_by_uid)
        && !('approved_at' in req)
        && !('approved_by_uid' in req)
        && !('rejection_note' in req);
    }
    // serverTimestamp() fields: use == request.time (reliable) instead of "is timestamp" in some clients/transactions.
    function walkInApprove(res, req) {
      return res.status == 'pending'
        && req.status == 'approved'
        && req.payment_status == 'paid'
        && req.line_count == res.line_count
        && req.created_at == res.created_at
        && req.sale_date == res.sale_date
        && (!('created_by_uid' in res) || req.created_by_uid == res.created_by_uid)
        && req.approved_by_uid is string
        && !('rejection_note' in req)
        && req.approved_at == request.time
        && req.paid_at == request.time
        && req.updated_at == request.time;
    }
    function walkInReject(res, req) {
      return res.status == 'pending'
        && req.status == 'rejected'
        && req.created_at == res.created_at
        && req.sale_date == res.sale_date
        && req.updated_at is timestamp
        && (!('rejection_note' in req) || (req.rejection_note is string && req.rejection_note.size() <= 500))
        && !('approved_at' in req)
        && !('approved_by_uid' in req);
    }
    function walkInDeleteApproved(res, req) {
      return res.status == 'approved'
        && req.status == 'rejected'
        && req.created_at == res.created_at
        && req.sale_date == res.sale_date
        && req.updated_at is timestamp
        && req.rejection_note is string
        && req.rejection_note.size() <= 500
        && !('approved_at' in req)
        && !('approved_by_uid' in req);
    }
    function walkInMarkPaid(res, req) {
      return res.status == 'approved'
        && req.status == 'approved'
        && req.created_at == res.created_at
        && req.sale_date == res.sale_date
        && req.line_count == res.line_count
        && req.approved_at == res.approved_at
        && req.approved_by_uid == res.approved_by_uid
        && (!('created_by_uid' in res) || req.created_by_uid == res.created_by_uid)
        && (!('rejection_note' in res) && !('rejection_note' in req))
        && req.payment_status == 'paid'
        && req.paid_at == request.time
        && req.updated_at == request.time;
    }
    match /walk_in_sessions/{sessionId} {
      allow read: if isStaff();
      allow create: if isStaff() && validWalkInSessionCreate(request.resource.data);
      allow update: if isStaff() && walkInStaffEditPending(resource.data, request.resource.data)
        || (isAdmin() && walkInApprove(resource.data, request.resource.data))
        || (isAdmin() && walkInReject(resource.data, request.resource.data))
        || (isAdmin() && walkInDeleteApproved(resource.data, request.resource.data))
        || (isAdmin() && walkInMarkPaid(resource.data, request.resource.data));
      allow delete: if isStaff() && resource.data.status == 'pending';
    }
    match /walk_in_sessions/{sessionId}/lines/{lineId} {
      allow read: if isStaff();
      allow create: if isStaff() && validWalkInLine(request.resource.data)
        && get(/databases/$(database)/documents/walk_in_sessions/$(sessionId)).data.status == 'pending';
      allow update: if isStaff() && validWalkInLine(request.resource.data)
        && request.resource.data.created_at == resource.data.created_at
        && get(/databases/$(database)/documents/walk_in_sessions/$(sessionId)).data.status == 'pending';
      allow delete: if isStaff()
        && get(/databases/$(database)/documents/walk_in_sessions/$(sessionId)).data.status == 'pending';
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
