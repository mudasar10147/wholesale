# Copy to .env.local and fill values from Firebase Console → Project settings → Your apps → Web app config.
# See docs/FIREBASE_PHASE1.md

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# POS receipt (optional branding — see lib/invoices/posReceiptBranding.ts)
NEXT_PUBLIC_POS_SHOP_NUMBER=

# Google Cloud Storage (product images, etc.) — server-only; never NEXT_PUBLIC_
# Local: set GOOGLE_APPLICATION_CREDENTIALS to a key file path; omit GCS_SERVICE_ACCOUNT_JSON.
# Vercel: set all three; paste the entire downloaded key JSON as one value for GCS_SERVICE_ACCOUNT_JSON (see docs/GCS_VERCEL.md).
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
# GCS_SERVICE_ACCOUNT_JSON=

